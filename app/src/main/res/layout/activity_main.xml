<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Screen Watcher"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitors a screen region and alarms on change"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select a region to begin."
                android:textSize="16sp"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- Sensitivity card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Min changed pixels: 10"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:layout_marginBottom="12dp" />

            <SeekBar
                android:id="@+id/seekbarThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="10"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lower = more sensitive"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSelect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="1.  Select Screen Region"
            android:textSize="16sp"
            android:backgroundTint="@color/btn_neutral"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="2.  Start Monitoring"
            android:textSize="16sp"
            android:backgroundTint="@color/btn_start"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Stop Monitoring"
            android:textSize="16sp"
            android:backgroundTint="@color/btn_stop"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="While monitoring, a notification with Recapture region and Stop actions is shown. The alarm plays via your alarm audio stream."
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:textAlignment="center"
            android:paddingHorizontal="8dp" />

    </LinearLayout>
</ScrollView>
